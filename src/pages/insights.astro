---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Mental Health Insights & Resources | Challa's Counsel" 
  description="Educational articles and practical resources covering stress management, boundary setting, and relationship healing."
>
  <!-- Hero -->
  <section class="relative min-h-[40vh] flex items-center bg-canvas pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-6 w-full">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-primary block mb-4">Resources</span>
        <h1 class="font-sans font-bold text-4xl sm:text-5xl lg:text-6xl text-ink leading-tight tracking-tight">
          Educational articles & <span class="font-display italic font-normal text-secondary">practical tools</span>.
        </h1>
        <p class="text-base sm:text-lg text-body leading-relaxed max-w-xl mx-auto mt-6">
          Evidence-based strategies, nervous system grounding exercises, and mental health perspectives.
        </p>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section class="py-24 bg-canvas border-t border-border/40">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-12 stagger-children">
        <!-- Article 1 -->
        <article class="group bg-card rounded-lg border border-border/50 overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300 flex flex-col">
          <div class="h-56 overflow-hidden bg-canvas-warm">
            <img 
              src="https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=700&auto=format&fit=crop&q=80" 
              alt="Tea mug and notes" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
            />
          </div>
          <div class="p-8 flex-grow flex flex-col">
            <div class="flex items-center gap-3 mb-5">
              <span class="text-[10px] font-bold uppercase tracking-wider bg-canvas-warm text-secondary px-2.5 py-1 rounded-sm">Somatic</span>
              <span class="text-xs text-body">6 Min Read</span>
            </div>
            <h3 class="font-sans font-bold text-xl text-ink mb-3 leading-snug">5 Somatic Grounding Exercises for Acute Anxiety</h3>
            <p class="text-sm text-body leading-relaxed mb-6 flex-grow">Learn nervous system regulation techniques to discharge adrenaline and return safely to the present moment.</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-sm font-semibold text-ink hover:text-secondary transition-colors group">
              Read Guide 
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </article>

        <!-- Article 2 -->
        <article class="group bg-card rounded-lg border border-border/50 overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300 flex flex-col">
          <div class="h-56 overflow-hidden bg-canvas-warm">
            <img 
              src="https://images.unsplash.com/photo-1516414447565-b14be0adf13e?w=700&auto=format&fit=crop&q=80" 
              alt="Work table with journals" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
            />
          </div>
          <div class="p-8 flex-grow flex flex-col">
            <div class="flex items-center gap-3 mb-5">
              <span class="text-[10px] font-bold uppercase tracking-wider bg-canvas-warm text-primary px-2.5 py-1 rounded-sm">Burnout</span>
              <span class="text-xs text-body">8 Min Read</span>
            </div>
            <h3 class="font-sans font-bold text-xl text-ink mb-3 leading-snug">The Burnout Recovery Blueprint</h3>
            <p class="text-sm text-body leading-relaxed mb-6 flex-grow">A structured framework to establish sustainable professional boundaries and detach identity from work output.</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-sm font-semibold text-ink hover:text-primary transition-colors group">
              Read Guide 
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </article>

        <!-- Article 3 -->
        <article class="group bg-card rounded-lg border border-border/50 overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300 flex flex-col">
          <div class="h-56 overflow-hidden bg-canvas-warm">
            <img 
              src="https://images.unsplash.com/photo-1576092768241-dec231879fc3?w=700&auto=format&fit=crop&q=80" 
              alt="Two chairs in empty room" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
            />
          </div>
          <div class="p-8 flex-grow flex flex-col">
            <div class="flex items-center gap-3 mb-5">
              <span class="text-[10px] font-bold uppercase tracking-wider bg-canvas-warm text-secondary px-2.5 py-1 rounded-sm">Relational</span>
              <span class="text-xs text-body">7 Min Read</span>
            </div>
            <h3 class="font-sans font-bold text-xl text-ink mb-3 leading-snug">Dismantling Codependency & Restoring Agency</h3>
            <p class="text-sm text-body leading-relaxed mb-6 flex-grow">Distinguish between empathetic validation and codependent caretaking patterns in your relationships.</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-sm font-semibold text-ink hover:text-secondary transition-colors group">
              Read Guide 
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Newsletter & Breathing -->
  <section class="py-24 bg-canvas border-t border-border/40">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 stagger-children">
      <!-- Grounding widget -->
      <div class="bg-card rounded-lg p-8 border border-border/50 shadow-card flex flex-col justify-between hover:shadow-card-hover transition-all duration-300">
        <div>
          <h3 class="font-sans font-bold text-xl text-ink mb-2">Quick Grounding Tool</h3>
          <p class="text-sm text-body leading-relaxed mb-6">Start a 1-minute guided box breathing exercise to settle your nervous system.</p>
          <div id="breathing-widget" class="hidden border border-primary/25 bg-canvas p-6 rounded-md text-center space-y-4 mb-6 transition-all duration-300">
            <span id="breathing-status" class="text-xs font-bold uppercase tracking-wider text-secondary block">Ready</span>
            <div class="w-24 h-24 rounded-full border-2 border-primary flex items-center justify-center mx-auto transition-all duration-[4000ms] ease-in-out" id="breathing-circle">
              <span id="breathing-sec" class="text-base font-bold text-ink">In</span>
            </div>
          </div>
        </div>
        <button id="btn-start-breathing" class="w-full py-4 rounded-sm bg-ink hover:bg-zinc-800 text-white font-semibold text-sm transition-all duration-300 cursor-pointer">Start Guided Breath</button>
      </div>

      <!-- Newsletter -->
      <div class="bg-card rounded-lg p-8 border border-border/50 shadow-card flex flex-col justify-between hover:shadow-card-hover transition-all duration-300">
        <div>
          <h3 class="font-sans font-bold text-xl text-ink mb-2">Insights Newsletter</h3>
          <p class="text-sm text-body leading-relaxed mb-6">Receive clinical, research-backed advice on stress reduction, parenting, and emotional boundaries.</p>
          <form id="newsletter-form" class="space-y-4">
            <input type="email" id="newsletter-email" required placeholder="name@email.com" class="w-full bg-canvas border border-border rounded-sm px-5 py-3.5 text-sm focus:border-secondary focus:outline-none transition-colors text-ink" />
            <button type="submit" class="w-full py-4 rounded-sm bg-primary hover:bg-primary-dark text-ink font-semibold text-sm transition-all duration-300 cursor-pointer">Subscribe</button>
          </form>
          <div id="newsletter-success" class="hidden p-5 bg-canvas border border-primary/20 text-ink text-sm rounded-md text-center font-semibold mt-4">Thank you for subscribing!</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const newsletterForm = document.getElementById('newsletter-form');
  const newsletterSuccess = document.getElementById('newsletter-success');
  newsletterForm?.addEventListener('submit', (e) => { 
    e.preventDefault(); 
    if (newsletterForm) newsletterForm.style.display = 'none'; 
    newsletterSuccess?.classList.remove('hidden'); 
  });

  const startBtn = document.getElementById('btn-start-breathing');
  const breathingWidget = document.getElementById('breathing-widget');
  const breathingStatus = document.getElementById('breathing-status');
  const breathingSec = document.getElementById('breathing-sec');
  const breathingCircle = document.getElementById('breathing-circle');
  let breathInterval: any = null, activeState = false;

  startBtn?.addEventListener('click', () => {
    if (activeState) { 
      clearInterval(breathInterval); 
      activeState = false; 
      startBtn.textContent = 'Start Guided Breath'; 
      breathingWidget?.classList.add('hidden'); 
      return; 
    }
    activeState = true; 
    startBtn.textContent = 'Stop Guided Breath'; 
    breathingWidget?.classList.remove('hidden'); 
    runBreathingCycle();
  });

  function runBreathingCycle() {
    let step = 0;
    const states = [
      { text: "Breathe In", count: 4, scale: "scale-110 bg-primary/10" },
      { text: "Hold", count: 4, scale: "scale-110 bg-primary/5" },
      { text: "Breathe Out", count: 4, scale: "scale-95 bg-transparent" },
      { text: "Hold", count: 4, scale: "scale-95 bg-transparent" }
    ];
    function update() {
      if (!activeState) return;
      const c = states[step];
      if (breathingStatus) breathingStatus.textContent = c.text;
      if (breathingCircle) {
        breathingCircle.className = `w-24 h-24 rounded-full border-2 border-primary flex items-center justify-center mx-auto transition-all duration-[4000ms] ease-in-out ${c.scale}`;
      }
      let count = c.count; 
      if (breathingSec) breathingSec.textContent = count.toString();
      const t = setInterval(() => { 
        count--; 
        if (breathingSec) breathingSec.textContent = count.toString(); 
        if (count <= 0) { 
          clearInterval(t); 
          step = (step + 1) % 4; 
          update(); 
        } 
      }, 1000);
      breathInterval = t;
    }
    update();
  }
</script>
